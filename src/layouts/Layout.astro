---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Bouldering guide for Bahratal, Elbsandstein' } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-stone-950 text-stone-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />

    <footer class="border-t border-stone-800 py-4 text-center text-xs text-stone-500 shrink-0">
      Data from <a href="https://gulag-online.de/bahratal-1.html" target="_blank" class="text-amber-500 hover:underline">gulag-online.de</a>
      · Bahratal, Elbsandstein
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
